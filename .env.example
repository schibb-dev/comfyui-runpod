# Copy to `.env` and customize. docker-compose reads this automatically.

# ComfyUI git ref at **image build** (Dockerfile: git checkout in /ComfyUI).
# Repo default (in docker-compose.yml) is already pinned for TeaCache — omit this to use it.
#
# Pin (explicit, same as compose default — ComfyUI-TeaCache compatible):
COMFYUI_REF=38d049382533c6662d815b08ca3395e96cca9f57
#
# Bleeding-edge ComfyUI (will break welltop-cn ComfyUI-TeaCache until that node is updated):
# COMFYUI_REF=origin/master

# MultiGPU folder toggle at container start (default true in docker-compose). Set false for single-GPU only.
# INSTALL_MULTIGPU=true

# If ComfyUI portable (or another app) uses 127.0.0.1:8188, http://127.0.0.1:8188 is NOT Docker — use a free port:
# COMFYUI_HOST_PORT=8189

# Host port for Vite HMR when running *inside* the comfyui container (docker-compose maps host:container).
# Default 51780 leaves host :5178 free for `npm run ui:dev:start` / `ui:dev:vite` on the machine.
# EXPERIMENTS_UI_VITE_HOST_PORT=51780

# --- Models (pick ONE style for where you run `docker compose`) ---
# Windows (PowerShell / CMD), models on E::
# COMFYUI_MODELS_DIR=E:\models
#
# WSL2 / Linux, same physical files on Windows drive E: (Docker Desktop must share E:):
# COMFYUI_MODELS_DIR=/mnt/e/models

# --- Optional: heavy data on E: (shadow tree), WSL paths ---
# When the canonical checkout lives on the Linux filesystem but input/output/comfyui_user
# (and optional credentials) stay under E:\comfyui-runpod-shadow, set these so both
# /ComfyUI/* and /workspace/* see the same host directories (watch scripts use /workspace/output/...).
# Defaults omit these lines (Compose uses ./workspace/... next to the repo).
#
# COMFYUI_BIND_INPUT_DIR=/mnt/e/comfyui-runpod-shadow/workspace/input
# COMFYUI_BIND_OUTPUT_DIR=/mnt/e/comfyui-runpod-shadow/workspace/output
# COMFYUI_BIND_USER_DIR=/mnt/e/comfyui-runpod-shadow/workspace/comfyui_user
# COMFYUI_BIND_CREDENTIALS_DIR=/mnt/e/comfyui-runpod-shadow/credentials

# --- Hot workspace data on WSL ext4 (recommended; set via scripts/wsl_setup_ext4_data.sh) ---
# COMFYUI_EXT4_DATA_ROOT=/home/<you>/data/comfyui-runpod
# COMFYUI_BIND_INPUT_DIR=/home/<you>/data/comfyui-runpod/input
# COMFYUI_BIND_OUTPUT_DIR=/home/<you>/data/comfyui-runpod/output
# COMFYUI_BIND_USER_DIR=/home/<you>/data/comfyui-runpod/comfyui_user
