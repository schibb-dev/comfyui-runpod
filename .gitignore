# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# ComfyUI specific
input/
output/
temp/
*.log

# Cache directories
.cache/
**/.cache/

# Models and large files (never commit these large files)
models/
*.safetensors
*.ckpt
*.gguf
*.bin
*.pt
*.pth

# Credentials (never commit these)
credentials/
.env
*.token
workspace/.civitai_token
workspace/.huggingface_token
workspace/.hf_token

# Workspace runtime / local state
workspace/_tmp/
workspace/output/
workspace/input/
workspace/comfyui_user/
workspace/ComfyUI
workspace/comfyui-wan

# Docker
.dockerignore

# Node.js (if any)
node_modules/
npm-debug.log*

# Experiments UI build output (served at runtime)
workspace/experiments_ui/dist/

# Custom nodes git directories (we don't want to track these as submodules)
**/.git/
custom_nodes/**/.git
workspace/**/.git

# Custom nodes (cloned by bootstrap from custom_nodes.yaml; do not track)
custom_nodes/
ComfyUI-Custom-Scripts/
